# Ancroo Default Environment Variables
ANCROO_PORT=8900
ANCROO_DOMAIN=ancroo.localhost
ANCROO_DB=ancroo
ANCROO_SECRET_KEY=CHANGE_ME_generate_with_openssl

# Backend selection for example workflows (comma-separated: cuda,rocm)
ANCROO_BACKENDS=cuda

# n8n integration
ANCROO_N8N_URL=http://n8n:5678
ANCROO_N8N_API_KEY=

# Ollama
ANCROO_OLLAMA_URL=http://ollama:11434
ANCROO_OLLAMA_MODEL=mistral:7b

# Whisper / Speaches STT
ANCROO_WHISPER_URL=http://speaches:8000
ANCROO_WHISPER_MODEL=Systran/faster-whisper-large-v3-turbo
# Whisper-ROCm GPU (leave empty to skip auto-provisioning)
ANCROO_WHISPER_ROCM_URL=
ANCROO_WHISPER_ROCM_MODEL=openai/whisper-large-v3-turbo

# Keycloak SSO (set by SSO module post-enable.sh)
ANCROO_KEYCLOAK_URL=http://keycloak:8080
ANCROO_KEYCLOAK_REALM=ancroo
ANCROO_KEYCLOAK_CLIENT_ID=ancroo
