# Ancroo Server — Environment Configuration
# Copy to .env and fill in values before starting.

# Required
SECRET_KEY=          # Application secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
DATABASE_URL=postgresql+asyncpg://ancroo:ancroo@localhost:5432/ancroo

# Authentication (disabled by default)
AUTH_ENABLED=false
OIDC_ISSUER=http://keycloak:8080/realms/ancroo
KEYCLOAK_CLIENT_ID=ancroo
KEYCLOAK_REALM=ancroo

# n8n integration
N8N_URL=http://n8n:5678
N8N_API_KEY=

# Ollama LLM
OLLAMA_BASE_URL=http://ollama:11434

# Whisper / Speaches STT
WHISPER_BASE_URL=http://speaches:8000
WHISPER_MODEL=Systran/faster-whisper-large-v3

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["chrome-extension://"]

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
