# Ancroo Server — Standalone Configuration
# Copy to .env and adjust values before starting.

# --- Required ---
SECRET_KEY=           # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# --- Database ---
# Option A: Use bundled PostgreSQL (--profile db). Set password only:
POSTGRES_PASSWORD=    # Choose a password for the bundled database

# Option B: Use your own PostgreSQL. Set full connection string:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- Optional integrations ---
# OLLAMA_BASE_URL=http://localhost:11434
# WHISPER_BASE_URL=http://localhost:8000
# WHISPER_MODEL=Systran/faster-whisper-large-v3
# ACTIVEPIECES_URL=http://localhost:8080
# ACTIVEPIECES_API_KEY=

# --- Server ---
# ANCROO_PORT=8900
# TZ=UTC
